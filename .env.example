# StellarTok backend API this frontend talks to
NEXT_PUBLIC_STELLARTOK_API_URL=http://localhost:4000

# Canonical URL this app is deployed at — used for metadataBase, Open Graph
# share previews, and the sitemap. Must be an absolute URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret used to HMAC-sign session cookies (TikTok identity + connected
# wallet). There is NO safe default — a missing or guessable value lets a
# client forge a session and impersonate any creator or wallet.
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# TikTok Login Kit / API credentials
NEXT_PUBLIC_TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
NEXT_PUBLIC_TIKTOK_REDIRECT_URI=http://localhost:3000/auth/callback/tiktok

# Stellar network to target (testnet while in development)
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# USDC issuer account for each network. There is NO safe default — verify
# the correct issuer against https://stellar.expert or Circle's published
# issuer list before setting this. A wrong value silently misroutes USDC
# payments. Only the value matching NEXT_PUBLIC_STELLAR_NETWORK is required.
STELLAR_USDC_ISSUER_MAINNET=
STELLAR_USDC_ISSUER_TESTNET=

# Platform fee taken on tips/campaign payouts, as a decimal (0.01 = 1%)
NEXT_PUBLIC_PLATFORM_FEE=0.01
